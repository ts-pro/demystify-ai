{
  "manifest_version": 3,
  "name": "Demystify AI",
  "version": "1.0.0",
  "description": "Explain and simplify selected text using OpenAI or Anthropic AI, with per-term tooltips and your choice of 12 languages.",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_icon": "icons/icon-48.png" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "web_accessible_resources": [
    {
      "resources": ["content/popup.css"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["prompts/system-prompt.txt"],
      "matches": []
    }
  ],
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
}
